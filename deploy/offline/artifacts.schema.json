{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dc-agent.local/schemas/offline-artifacts.schema.json",
  "title": "DC-Agent offline artifact manifest",
  "description": "A closed manifest of checksummed artifacts provisioned on the offline host.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifacts"
  ],
  "properties": {
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/artifact"
      }
    }
  },
  "$defs": {
    "artifact": {
      "description": "Local Docling artifacts, PaddleOCR detection models, PaddleOCR recognition models, PaddleOCR classification models, PaddlePaddle CPU wheels, LibreOffice binaries, and Poppler/native libraries, each with identity, license, checksum, and path metadata.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "kind",
        "version",
        "sha256",
        "license",
        "localPath"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": ".*\\S.*"
        },
        "kind": {
          "type": "string",
          "pattern": ".*\\S.*"
        },
        "version": {
          "type": "string",
          "pattern": ".*\\S.*"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "license": {
          "type": "string",
          "pattern": ".*\\S.*"
        },
        "localPath": {
          "type": "string",
          "pattern": "^(?=.*\\S)(?:\\s*[A-Za-z]:[\\\\/]|(?!\\s*(?:[A-Za-z][A-Za-z0-9+.-]*:|[\\\\/]{2}))).*$"
        }
      }
    }
  }
}
