# Copy this file to backend/.env for local development.
# Shell environment variables still take priority over values in this file.

DATABASE_URL=postgresql+psycopg://postgres:123456@127.0.0.1:5432/dc_agent

# Filters weak retrieval results before they reach the Agent or LLM.
RETRIEVAL_MIN_SCORE=2.2

# Local deterministic fallback.
LLM_PROVIDER=template

# Real model mode. Uncomment and fill these values for live RAG answers.
# LLM_PROVIDER=openai_compatible
# LLM_API_BASE=https://your-llm-host.example/v1
# LLM_API_KEY=replace-with-your-api-key
# LLM_MODEL=your-model-name
